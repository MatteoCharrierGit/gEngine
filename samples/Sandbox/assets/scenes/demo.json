    {
      "name": "player",
      "_comment": "Player: Transform + MeshRenderer + Velocity + Player (custom). Serve almeno un'entità con Velocity: SandboxGame.Draw fa .First() su Query<Transform,Velocity>. Ha un 'name' per essere referenziato come genitore.",
      "components": {
        "Transform": { "Position": { "x": 0, "y": 1.5, "z": 0 }, "Rotation": { "w": 0.7071, "y": -0.7071 }, "Scale": { "x": 1, "y": 1, "z": 1 } },
